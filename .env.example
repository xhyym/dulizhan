# ===== 数据库 =====
DB_HOST=mysql
DB_PORT=3306
DB_NAME=indie_station
DB_USERNAME=root
DB_PASSWORD=请改成你的数据库密码

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=请改成你的Redis密码

# ===== Cloudflare R2 =====
R2_ENDPOINT=请改成你的R2 Endpoint
R2_ACCESS_KEY=请改成你的R2 Access Key
R2_SECRET_KEY=请改成你的R2 Secret Key
R2_BUCKET=dulizhan
R2_PUBLIC_URL=请改成你的R2 Public URL

# ===== 前端 Next.js =====
# 后端 API 地址（前端构建时注入，需要重新构建才能生效）
NEXT_PUBLIC_API_URL=http://your-server-ip:8080
